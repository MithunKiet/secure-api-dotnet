# ==============================================
# Secure API Foundation - Environment Variables
# ==============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# === Database ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=secure_api_foundation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# === JWT ===
# Must be at least 32 characters. Use a cryptographically secure random string.
JWT_SECRET_KEY=your_very_strong_jwt_secret_key_here_min_32_chars
JWT_ISSUER=SecureApiFoundation
JWT_AUDIENCE=SecureApiFoundation
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# === CORS ===
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# === ASP.NET Core ===
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
